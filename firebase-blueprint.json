{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "studentId": { "type": "string" },
        "highScore": { "type": "number" },
        "gamesPlayed": { "type": "number" },
        "avgReactionTime": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName"]
    },
    "Score": {
      "title": "Leaderboard Score",
      "description": "A single score entry for the leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "score": { "type": "number" },
        "labId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "score"]
    },
    "Badge": {
      "title": "Earned Badge",
      "description": "A unique SVG badge earned by a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "labId": { "type": "string" },
        "badgeName": { "type": "string" },
        "svgIcon": { "type": "string" },
        "earnedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "labId", "badgeName", "svgIcon", "earnedAt"]
    },
    "Presence": {
      "title": "Active Player Presence",
      "description": "Real-time presence of a player",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "studentId": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "playing", "gameover"] },
        "score": { "type": "number" },
        "activeLab": { "type": "string" },
        "lastActive": { "type": "object" }
      },
      "required": ["uid", "displayName", "status"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Capstone project feedback",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "overallRating": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "overallRating", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Leaderboard scores"
    },
    "/badges/{badgeId}": {
      "schema": "Badge",
      "description": "Earned unique badges"
    },
    "/active_players/{userId}": {
      "schema": "Presence",
      "description": "Active players"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback"
    },
    "/studentIds/{studentId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Student ID uniqueness index"
    }
  }
}
